generator client {
  provider   = "prisma-client"
  output     = "../generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum BillingProvider {
  PADDLE
}

enum BillingSubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  PAUSED
  CANCELED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketChannel {
  PORTAL
  EMAIL
  PHONE
  MANUAL
}

model User {
  id                    String         @id @default(cuid())
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  email                 String         @unique
  emailVerified         Boolean        @default(false)
  name                  String
  image                 String?
  currentOrganizationId String?
  currentOrganization   Organization?  @relation("CurrentOrganization", fields: [currentOrganizationId], references: [id], onDelete: SetNull)
  accounts              Account[]
  sessions              Session[]
  memberships           Membership[]
  auditEvents           AuditEvent[]   @relation("ActorAuditEvents")
  invitationsSent       Invitation[]   @relation("InvitationSender")
  ownedOrganizations    Organization[] @relation("OwnedOrganizations")
  ticketsCreated        Ticket[]         @relation("TicketCreator")
  ticketsAssigned       Ticket[]         @relation("TicketAssignee")
  ticketComments        TicketComment[]   @relation("AgentComment")
}

model Session {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  providerId            String
  accountId             String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  value      String
  expiresAt  DateTime
  identifier String

  @@unique([identifier, value])
  @@index([expiresAt])
}

model Organization {
  id                   String                @id @default(cuid())
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  name                 String
  slug                 String                @unique
  planKey              String                @default("free")
  ticketPrefix         String                @default("TKT")
  billingEmail         String?
  ownerId              String
  owner                User                  @relation("OwnedOrganizations", fields: [ownerId], references: [id], onDelete: Restrict)
  currentUsers         User[]                @relation("CurrentOrganization")
  memberships          Membership[]
  invitations          Invitation[]
  auditEvents          AuditEvent[]          @relation("OrganizationAuditEvents")
  billingCustomer      BillingCustomer?
  billingSubscription  BillingSubscription?
  billingWebhookEvents BillingWebhookEvent[]
  contacts             Contact[]
  tickets              Ticket[]
  ticketComments       TicketComment[]
  cannedResponses      CannedResponse[]
  slaPolicies          SlaPolicy[]
  ticketTags           TicketTag[]
  helpdeskSettings     HelpdeskSettings?
}

model Membership {
  id             String         @id @default(cuid())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organizationId String
  userId         String
  role           MembershipRole @default(OWNER)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model Invitation {
  id              String           @id @default(cuid())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  organizationId  String
  email           String
  role            MembershipRole   @default(MEMBER)
  token           String           @unique
  status          InvitationStatus @default(PENDING)
  invitedByUserId String?
  expiresAt       DateTime
  lastSentAt      DateTime?
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedByUser   User?            @relation("InvitationSender", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@unique([organizationId, email])
  @@index([status, expiresAt])
}

model AuditEvent {
  id             String        @id @default(cuid())
  createdAt      DateTime      @default(now())
  organizationId String?
  actorUserId    String?
  type           String
  targetType     String?
  targetId       String?
  ipAddress      String?
  userAgent      String?
  payload        Json?
  organization   Organization? @relation("OrganizationAuditEvents", fields: [organizationId], references: [id], onDelete: SetNull)
  actorUser      User?         @relation("ActorAuditEvents", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([actorUserId, createdAt])
}

model EmailWebhookEvent {
  id            String   @id @default(cuid())
  externalId    String   @unique
  type          String
  resendEmailId String?
  payload       Json
  createdAt     DateTime @default(now())
  processedAt   DateTime @default(now())

  @@index([type, createdAt])
}

model BillingCustomer {
  id                 String          @id @default(cuid())
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  organizationId     String          @unique
  provider           BillingProvider @default(PADDLE)
  providerCustomerId String          @unique
  email              String
  name               String?
  organization       Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([provider, email])
}

model BillingSubscription {
  id                     String                    @id @default(cuid())
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  organizationId         String                    @unique
  provider               BillingProvider           @default(PADDLE)
  providerSubscriptionId String                    @unique
  providerTransactionId  String?
  providerPriceId        String
  planKey                String
  status                 BillingSubscriptionStatus
  currencyCode           String
  quantity               Int                       @default(1)
  currentPeriodStartsAt  DateTime?
  currentPeriodEndsAt    DateTime?
  nextBilledAt           DateTime?
  trialEndsAt            DateTime?
  cancelAtPeriodEnd      Boolean                   @default(false)
  canceledAt             DateTime?
  organization           Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([provider, status])
}

model BillingWebhookEvent {
  id              String          @id @default(cuid())
  receivedAt      DateTime        @default(now())
  processedAt     DateTime        @default(now())
  organizationId  String?
  provider        BillingProvider @default(PADDLE)
  providerEventId String          @unique
  eventType       String
  payload         Json
  organization    Organization?   @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([provider, eventType, receivedAt])
  @@index([organizationId, receivedAt])
}

model HelpdeskSettings {
  id                   String       @id @default(cuid())
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  organizationId       String       @unique
  fromName             String?
  fromEmail            String?
  resendApiKey         String?
  inboundWebhookSecret String?
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Contact {
  id             String          @id @default(cuid())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organizationId String
  email          String
  name           String
  phone          String?
  company        String?
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tickets        Ticket[]
  comments       TicketComment[] @relation("ContactComment")

  @@unique([organizationId, email])
  @@index([organizationId, name])
}

model Ticket {
  id                     String         @id @default(cuid())
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  organizationId         String
  number                 Int
  displayId              String
  publicId               String         @unique
  title                  String
  description            String
  status                 TicketStatus   @default(OPEN)
  priority               TicketPriority @default(MEDIUM)
  channel                TicketChannel  @default(MANUAL)
  contactId              String
  createdById            String?
  assignedToId           String?
  closedAt               DateTime?
  slaFirstResponseDueAt  DateTime?
  slaResolutionDueAt     DateTime?
  firstRespondedAt       DateTime?
  organization           Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact                Contact        @relation(fields: [contactId], references: [id], onDelete: Restrict)
  createdBy              User?          @relation("TicketCreator", fields: [createdById], references: [id], onDelete: SetNull)
  assignedTo             User?          @relation("TicketAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  comments               TicketComment[]
  tags                   TicketTag[]

  @@unique([organizationId, number])
  @@unique([organizationId, displayId])
  @@index([organizationId, status, createdAt])
  @@index([organizationId, publicId])
  @@index([contactId])
  @@index([assignedToId])
}

model TicketComment {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  ticketId       String
  organizationId String
  authorId       String?
  contactId      String?
  body           String
  internal       Boolean      @default(false)
  ticket         Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author         User?        @relation("AgentComment", fields: [authorId], references: [id], onDelete: SetNull)
  contact        Contact?     @relation("ContactComment", fields: [contactId], references: [id], onDelete: SetNull)

  @@index([ticketId, createdAt])
  @@index([organizationId])
}

model CannedResponse {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String
  title          String
  body           String
  shortcut       String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, title])
  @@index([organizationId])
}

model SlaPolicy {
  id                     String         @id @default(cuid())
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  organizationId         String
  name                   String
  priority               TicketPriority
  firstResponseMinutes   Int
  resolutionMinutes      Int
  isDefault              Boolean        @default(false)
  organization           Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, priority])
  @@index([organizationId])
}

model TicketTag {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  organizationId String
  name           String
  color          String       @default("#6b7280")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tickets        Ticket[]

  @@unique([organizationId, name])
  @@index([organizationId])
}
